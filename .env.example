# Required: YugabyteDB / PostgreSQL connection string (libpq keyword format)
YUGABYTEDB_URL="host=localhost port=5433 dbname=yugabyte user=yugabyte password=yugabyte"

# Optional: log level for the 'yugabytedb-mcp' logger family
# YB_LOG_LEVEL=INFO

# Optional: transport (stdio is the default; use 'http' for self-hosted remote)
# YB_MCP_TRANSPORT=stdio
# YB_MCP_STATELESS_HTTP=true

# Optional: write-tool guardrail configuration
# YB_MCP_MAX_INSERT_ROWS=1000
# YB_MCP_REQUIRE_WHERE_ON_UPDATE=true
# YB_MCP_REQUIRE_WHERE_ON_DELETE=true

# Optional: AWS Secrets Manager-backed SSL root certificate
# YB_AWS_SSL_ROOT_CERT_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123:secret:my-cert
# YB_AWS_SSL_ROOT_CERT_SECRET_REGION=us-east-1
# YB_AWS_SSL_ROOT_CERT_KEY=root_ca   # only when secret JSON has multiple entries
# YB_SSL_ROOT_CERT_PATH=/tmp/yb-root.crt

# --- OAuth (self-hosted remote only) ---
# Leave MCP_AUTH_PROVIDER unset to disable auth (stdio dev / local use)
# MCP_AUTH_PROVIDER=cognito
# MCP_BASE_URL=http://localhost:8000

# Cognito (tested):
# COGNITO_USER_POOL_ID=eu-north-1_xxxxxxxxx
# COGNITO_AWS_REGION=eu-north-1
# COGNITO_CLIENT_ID=your-client-id
# COGNITO_CLIENT_SECRET=your-client-secret

# Generic OIDC (untested — use at your own risk):
# OIDC_CONFIG_URL=https://issuer.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_AUDIENCE=optional-audience
